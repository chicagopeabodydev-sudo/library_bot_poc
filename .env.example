CRAWL_URL=https://example.com
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=30
# Crawl writes .md files and, for event-like pages, same-basename .json sidecars here.
CRAWL_OUTPUT_DIR=website-markdown
# When enabled, stale .md and .json crawl artifacts are removed before a new run.
CRAWL_CLEAR_OUTPUT=1
CRAWL_RUN_INDEX=1

# Indexing and querying
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Also used for Crawl4AI event extraction on event-like pages.
OPENAI_API_KEY=sk-...
GUARDRAILS_ENABLED=1
GUARDRAILS_CONFIG_DIR=guardrails

# Optional CLI fallback for `python src/query.py`
QUERY_TEXT=What are the library hours?
